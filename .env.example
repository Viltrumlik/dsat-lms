# ═══════════════════════════════════════
# DSAT LMS v2 — Environment Variables
# ═══════════════════════════════════════
# Nusxa: cp .env.example .env
# .env ni hech qachon git'ga commit qilmang!

# ─────────────────────────────────────
# Django Core
# ─────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
DATABASE_URL=postgresql://dsat:dsat@postgres:5432/dsat_db
# Local (docker compose ichida "postgres", tashqaridan "localhost"):
# DATABASE_URL=postgresql://dsat:dsat@localhost:5432/dsat_db

# ─────────────────────────────────────
# Redis
# ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Local (tashqaridan): redis://localhost:6379/0

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
JWT_ROTATE_REFRESH_TOKENS=True

# ─────────────────────────────────────
# CORS
# ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────
# Storage
# ─────────────────────────────────────
STORAGE_BACKEND=local
# Production uchun: r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=dsat-lms-media
# R2_CUSTOM_DOMAIN=media.yourdomain.com

# ─────────────────────────────────────
# Email
# ─────────────────────────────────────
EMAIL_BACKEND_TYPE=console
# Production uchun: resend yoki ses
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@yourdomain.com

# ─────────────────────────────────────
# Celery
# ─────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────
# Sentry (optional dev da)
# ─────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# ─────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────
LOGIN_RATE_LIMIT=5/15m
REGISTER_RATE_LIMIT=10/1h
API_RATE_LIMIT=300/1m

# ─────────────────────────────────────
# Feature Flags (dev uchun)
# ─────────────────────────────────────
PUBLIC_PRACTICE_TEST_LIMIT_PER_WEEK=3
PUBLIC_PAST_PAPER_LIMIT=5
